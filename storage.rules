rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access
      allow read: if true;
      
      // Allow write access only to authenticated users (admins)
      allow write: if request.auth != null && 
                   (request.auth.token.email == "interiorsmadhav@gmail.com");
    }
  }
}
